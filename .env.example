# Digital Waybill API credentials
# Copy this file to .env and fill in your real values.
# .env is git-ignored so your key is never committed.

# Required
DWB_CID=your_company_id
DWB_KEY=your_api_key

# Optional - only for QuickEntry (customer-scoped) access
# DWB_CUSTOMER_NUMBER=DYN833
# DWB_PASSWORD=yourpassword
